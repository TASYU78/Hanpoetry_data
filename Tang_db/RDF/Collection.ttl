    rdfs:label "全唐詩"@ja ;
    hp:hasCollectionConcept <https://w3id.org/hanpoetry/resource/tang/concept/tangCollection> ;
    hp:hasDescription "清代编纂的大型唐诗总集，收录唐代诗人近五万首作品。"@zh ;
    hp:hasCreationTime "1705-01-01"^^xsd:date ;
    hp:hasAuthor <https://w3id.org/hanpoetry/resource/tang/person/jiputang> ;
